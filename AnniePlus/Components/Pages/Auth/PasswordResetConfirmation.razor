@page "/api/auth/ResetConfirmation"

@using System.Security.Claims
@using Annie_API.DTOs
@using Microsoft.AspNetCore.Components.Authorization

@inject HttpClient Http
@inject NavigationManager Nav

<h3>Password Reset</h3>

<EditForm Model="passwordReset" OnValidSubmit="@HandleReset" FormName="PasswordResetConfirmationForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group mb-3">
        <label>Email:</label>
        <InputText class="form-control" @bind-Value="passwordReset.Email" />
        <ValidationMessage For="@(() => passwordReset.Email)" />
    </div>

    <div class="form-group mb-3">
        <label>Password:</label>
        <InputText type="password" class="form-control" @bind-Value="passwordReset.NewPassword" />
        <ValidationMessage For="@(() => passwordReset.NewPassword)"/>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @errorMessage
        </div>
    }

    <button type="submit" class="btn btn-primary">Reset Password</button>

</EditForm>



@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = null!;

    private ClaimsPrincipal? claimsPrincipal;
    private PasswordResetDTO passwordReset = new();
    private string? errorMessage;

    [Parameter, SupplyParameterFromQuery] public string Token { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask;
        if (authState == null) return;

        claimsPrincipal = authState.User;

        if (claimsPrincipal.Claims.Count() != 0)
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task HandleReset()
    {
        passwordReset.Token = Token;

        var response = await Http.PostAsJsonAsync("api/auth/ResetConfirmation", passwordReset);

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/login");
            return;
        }
        else
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            return;
        }
    }
}

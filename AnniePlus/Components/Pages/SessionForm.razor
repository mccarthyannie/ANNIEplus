@page "/create-session"
@page "/edit-session/{Id:long}"

@inject AuthenticationStateProvider AuthProvider
@using Microsoft.EntityFrameworkCore
@using Annie_API.Models
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Annie_API.DTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Create Session</PageTitle>

<h3>@(isEditMode ? "Edit Session" : "Create Session")</h3>

<EditForm Model="session" OnValidSubmit="@HandleSubmit" FormName="Session">
    <DataAnnotationsValidator />
    <ValidationSummary />
   
    <div class="form-group mb-3">
        <label>Session Name:</label>
        <InputText @bind-Value="session.Name" class="form-control" />
        <ValidationMessage For="@(() => session.Name)" />
    </div>

    <div class="form-group mb-3">
        <label>Instructor:</label>
        <InputText @bind-Value="session.Instructor" class="form-control" />
        <ValidationMessage For="@(() => session.Instructor)" />
    </div>

    <div class="form-group mb-3">
        <label>Location:</label>
        <InputText @bind-Value="session.Location" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Class Capacity:</label>
        <InputNumber @bind-Value="session.Capacity" class="form-control" />
        <ValidationMessage For="@(() => session.Capacity)" />
    </div>
    
    <div class="form-group mb-3">
        <label>Session Description:</label>
        <InputTextArea @bind-Value="session.Description" class="form-control" rows="3"/>
        <ValidationMessage For="@(() => session.Description)" />
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Date:</label>
            <InputDate @bind-Value="sessionDate" class="form-control" @bind-Value:after="OnDateChanged"/>
        </div>
        <div class="col-md-6">
            <label class="form-label">Start Time:</label>
            <input type="time" class="form-control" value="@startTimeStr"
               @onchange="OnTimeChanged" step="900" />
        </div>
    </div>

    <div class="form-group mb-3">
        <label>Duration:</label>
        <div class="d-flex gap-2 flex-wrap mb-2">
            @foreach (var option in durationOptions)
            {
                <button type="button"
                    class="btn @(durationMinutes == option.min && !customDuration ? "btn-secondary" : "btn-outline-secondary") btn-sm"
                    @onclick="() => SetDuration(option.min)">
                    @option.label
                </button>
            }
            <button type="button"
                class="btn @(customDuration ? "btn-secondary" : "btn-outline-secondary") btn-sm"
                @onclick="EnableCustomDuration">
                Custom
            </button>
        </div>
        @if (customDuration)
        {
            <div class="d-flex align-items-center gap-2">
                <InputNumber @bind-Value="durationMinutes" class="form-control" style="width:120px"
                    @bind-Value:after="UpdateEndTime" min="15" max="480" step="15" />
                <span class="text-muted">minutes</span>
            </div>
        }
    </div>

    <div class="alert alert-light mb-3 py-2">
        End time: <strong>@session.EndTime.ToString("h:mm tt")</strong>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch"
                    @bind="showRecurrence" id="recurSwitch" />
                <label class="form-check-label" for="recurSwitch">Repeat this session</label>
            </div>

            @if (showRecurrence)
            {
                <hr />
                <label class="form-label">Repeat on:</label>
                <div class="d-flex gap-2 flex-wrap mb-2">
                    @foreach (var day in Enum.GetValues<DayOfWeek>())
                    {
                        var isLocked = day == sessionDate.DayOfWeek;
                        var isActive = selectedDays.Contains(day) || isLocked;
                        <button type="button"
                            class="btn btn-sm rounded-circle @(isActive ? "btn-secondary" : "btn-outline-secondary")"
                            style="width:42px;height:42px;"
                            disabled="@isLocked"
                            @onclick="() => ToggleDay(day)">
                            @day.ToString().Substring(0, 2)
                        </button>
                    }
                </div>
                <div class="mt-3">
                    <label class="form-label">Repeat Until:</label>
                    <InputDate @bind-Value="recurrenceEndDate" class="form-control" style="width:220px" />
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }

    @if (isEditMode)
    {
        @if (!confirmingDelete)
        {
            <button type="button" class="btn btn-outline-danger btn-sm me-2"
                @onclick="() => confirmingDelete = true">
                Delete Session
            </button>
        }
        else
        {
            <div class="alert alert-danger d-flex align-items-center gap-3 py-2">
                <span>Delete just this session or all with the same schedule?</span>
                <button type="button" class="btn btn-danger btn-sm"
                    @onclick="() => DeleteSession(false)">Just This One</button>
                <button type="button" class="btn btn-danger btn-sm"
                    @onclick="() => DeleteSession(true)">All in Series</button>
                <button type="button" class="btn btn-outline-secondary btn-sm"
                    @onclick="() => confirmingDelete = false">Cancel</button>
            </div>
        }
    }

    <button type="submit" class="btn btn-primary">
        @(isEditMode ? "Save Changes" : "Create Session")
    </button>
</EditForm>

@if (submitted)
{
    <div class="alert alert-success mt-3">
        <p>Your session has been made.</p>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = null!;
    [Parameter] public long? Id { get; set; }
    private bool isEditMode => Id.HasValue;

    private Session session = new Session 
    { 
        StartTime = DateTime.Today.AddHours(9), 
        EndTime = DateTime.Today.AddHours(10),
        Instructor = "", 
        Capacity = 0,
        Status = SessionStatus.Available,
    };

    private bool submitted = false;
    private string? errorMessage;
    private DateTime recurrenceEndDate = DateTime.Today.AddMonths(1);
    private HashSet<DayOfWeek> selectedDays = new();
    private DateOnly sessionDate = DateOnly.FromDateTime(DateTime.Today);
    private string startTimeStr = "09:00";
    private int durationMinutes = 60;
    private bool customDuration = false;
    private bool showRecurrence = false;
    private bool confirmingDelete = false;

    private (string label, int min)[] durationOptions = 
    {
        ("30 min", 30), ("1 hr", 60), ("1.5 hr", 90), ("2 hr", 120)
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var claimsPrincipal = authState.User;

        if (claimsPrincipal.Claims.Count() == 0)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var role = claimsPrincipal.Claims
            .FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
        if (role == "User" || role == null)
        {
            Nav.NavigateTo("/");
            return;
        }

        UpdateEndTime();

        if (isEditMode)
        {
            var result = await Http.GetFromJsonAsync<Session>($"api/Sessions/{Id}");
            if (result != null)
            {
                session = result;
                sessionDate = DateOnly.FromDateTime(result.StartTime);
                startTimeStr = result.StartTime.ToString("HH:mm");
                durationMinutes = (int)(result.EndTime - result.StartTime).TotalMinutes;
            }
        }

        StateHasChanged();
    }

    private void OnTimeChanged(ChangeEventArgs e)
    {
        startTimeStr = e.Value?.ToString() ?? "09:00";
        UpdateEndTime();
    }

    private void SetDuration(int min)
    {
        durationMinutes = min;
        customDuration = false;
        UpdateEndTime();
    }

    private void OnDateChanged()
    {
        UpdateEndTime();
        StateHasChanged();
    }

    private void UpdateEndTime()
    {
        var time = TimeSpan.TryParse(startTimeStr, out var t) ? t : TimeSpan.FromHours(9);
        session.StartTime = sessionDate.ToDateTime(TimeOnly.FromTimeSpan(time));
        session.EndTime = session.StartTime.AddMinutes(durationMinutes);
    }

    private void ToggleDay(DayOfWeek day)
    {
        if (selectedDays.Contains(day)) selectedDays.Remove(day);
        else selectedDays.Add(day);
    }

    private void EnableCustomDuration()
    {
        customDuration = true;
        UpdateEndTime();
    }

    private List<DateTime> GetRecurrenceDates()
    {
        var dates = new List<DateTime>();
        var current = session.StartTime.Date;
        var end = recurrenceEndDate.Date;
        var activeDays = new HashSet<DayOfWeek>(selectedDays) { sessionDate.DayOfWeek };

        while (current <= end)
        {
            if (activeDays.Contains(current.DayOfWeek))
                dates.Add(current);
            current = current.AddDays(1);
        }

        return dates;
    }

    private Session CreateRecurringSession(DateTime date)
    {
        var duration = session.EndTime - session.StartTime;
        return new Session
        {
            Name = session.Name,
            Instructor = session.Instructor,
            Location = session.Location,
            Capacity = session.Capacity,
            Description = session.Description,
            StartTime = DateTime.SpecifyKind(date + session.StartTime.TimeOfDay, DateTimeKind.Utc),
            EndTime = DateTime.SpecifyKind(date + session.StartTime.TimeOfDay + duration, DateTimeKind.Utc),
            Status = SessionStatus.Available,
        };
    }

    private async Task PostRecurringSessions(IEnumerable<DateTime> dates)
    {
        foreach (var d in dates)
            await Http.PostAsJsonAsync("api/Sessions", CreateRecurringSession(d));
    }

    private async Task DeleteSession(bool deleteSeries)
    {
        try
        {
            if (!deleteSeries)
            {
                var response = await Http.DeleteAsync($"api/Sessions/{Id}");
                if (!response.IsSuccessStatusCode) { errorMessage = await response.Content.ReadAsStringAsync(); return; }
            }
            else
            {
                var all = await Http.GetFromJsonAsync<List<Session>>("api/Sessions");
                if (all == null) return;

                var toDelete = all.Where(s =>
                    s.Name == session.Name &&
                    s.Instructor == session.Instructor &&
                    s.StartTime.TimeOfDay == session.StartTime.TimeOfDay);

                foreach (var s in toDelete)
                    await Http.DeleteAsync($"api/Sessions/{s.Id}");
            }

            Nav.NavigateTo("/schedule", true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        session.StartTime = DateTime.SpecifyKind(session.StartTime, DateTimeKind.Utc);
        session.EndTime = DateTime.SpecifyKind(session.EndTime, DateTimeKind.Utc);

        if (session.EndTime <= session.StartTime)
        {
            errorMessage = "Error: The session cannot end before it starts.";
            return;
        }

        try
        {
            if (isEditMode)
            {
                var response = await Http.PutAsJsonAsync($"api/Sessions/{Id}", session);
                if (!response.IsSuccessStatusCode) { errorMessage = await response.Content.ReadAsStringAsync(); return; }

                if (showRecurrence)
                    await PostRecurringSessions(GetRecurrenceDates().Where(d => d.Date != session.StartTime.Date));

                Nav.NavigateTo("/schedule", true);
            }
            else if (!showRecurrence)
            {
                var response = await Http.PostAsJsonAsync("api/Sessions", session);
                if (!response.IsSuccessStatusCode)
                    errorMessage = await response.Content.ReadAsStringAsync();
                else
                    Nav.NavigateTo("/schedule", true);
            }
            else
            {
                await PostRecurringSessions(GetRecurrenceDates());
                Nav.NavigateTo("/schedule", true);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving: {ex.Message}";
        }
    }
}
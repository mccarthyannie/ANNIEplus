@page "/create-session"
@using Microsoft.EntityFrameworkCore
@using Annie_API.Models
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Create Session</h3>

<EditForm Model="@session" OnValidSubmit="@HandleSubmit" FormName="Session">
    <DataAnnotationsValidator />
    <ValidationSummary />
   
    // input for session name
    <div class="form-group mb-3">
        <label>Session Name:</label>
        <InputText @bind-Value="session.Name" class="form-control" />
        <ValidationMessage For="@(() => session.Name)" />
    </div>

    // select instructor from list of instructors in the database
    <div class="form-group mb-3">
        <label>Instructor:</label>
        <InputSelect @bind-Value="session.InstructorId" class="form-control">
        <option value="0">Choose Instructor</option>
        @foreach (var instructor in Instructors)
        {
            <option value="@instructor.Id">@instructor.Name</option>
        }
        </InputSelect>
    </div>

    // select location from list of locations in the database
    <div class="form-group mb-3">
        <label>Location:</label>
        <InputSelect @bind-Value="session.LocationId" class="form-control">
            <option value="0">Choose Location</option>
            @foreach (var location in Locations)
            {
                <option value="@location.Id">@location.Name</option>
            }
        </InputSelect>
    </div>
    
    // input for session description
    <div class="form-group mb-3">
        <label>Session Description:</label>
        <InputText @bind-Value="session.Description" class="form-control" rows="3"/>
        <ValidationMessage For="@(() => SessionModel.SessionDescription)" />
    </div>

    // select the date
    <div class="row mb-3">
        <div class="col-12">
            <label>Session Date:</label>
            <InputDate Type="InputDateType.Date" @bind-Value="session.StartTime" class="form-control" />
        </div>
    </div>

    // select the start and end time
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Start Time:</label>
            <InputDate Type="InputDateType.Time" @bind-Value="session.StartTime" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">End Time:</label>
            <InputDate Type="InputDateType.Time" @bind-Value="session.EndTime" class="form-control" />
        </div>
    </div>
     
    <button type="submit" class="btn btn-primary">Create Session</button>

</EditForm>

@if (submitted)
{
    <div class"alert alert-success mt-3">
        <p>Your session "@session.Name" has been made.</p>
    </div>
}

@code {
    [SupplyParameterFromForm]
    private Session session { get; set; } = new() 
    {
        StartTime = DateTime.Today.AddHours(9),,
        EndTime = DateTime.Today.AddHours(10),
        Instructors = new List<string>(),
        Capacity = 45
    };

    private bool submitted = false;
    private string? errorMessage;
    private string? lastCreatedName;

    private async Task HandleSubmit()
    {
        session.EndTime = new DateTime(
            session.StartTime.Year, session.StartTime.Month, session.StartTime.Day, 
            session.EndTime.Hour, session.EndTime.Minute, 0
        );

        if (session.EndTime <= session.StartTime)
        {
            errorMessage = "Error: The session cannot end before it starts!";
            submitted = false;
            return;
        }

        try 
        {
            var response = await Http.PostAsJsonAsync("api/Sessions", session);
            if (response.IsSuccessStatusCode)
            {
                lastCreatedName = session.Name;
                submitted = true;
                errorMessage = null;

                session = new Session {
                    StartTime = DateTime.Today.AddHours(9),
                    EndTime = DateTime.Today.AddHours(10),
                    Instructors = new List<string>(),
                    Capacity = 45
                };
            }
            else
            {
                errorMessage = $"Server error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving: {ex.Message}";
        }
    }
}
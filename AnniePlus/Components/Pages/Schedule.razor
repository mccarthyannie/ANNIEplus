@page "/schedule"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Annie_API.Models
@using AnniePlus.Components.Pages
@using Annie_API.DTOs
@inject HttpClient Http
@using System.Security.Claims
@using Microsoft.VisualStudio.Web.CodeGenerators.Mvc.Templates.BlazorIdentity.Pages
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>Schedule</PageTitle>
<div class="schedule-page">
    <div class="schedule-nav d-flex align-items-center justify-content-between p-3">
       <button class="btn" @onclick="GoToPreviousWeek">
            <i class="bi bi-chevron-left"></i>
            <h6>Previous</h6>
        </button>  
        
        <h1 class="m-0">@currentStartDate.ToString("MMMM yyyy")</h1>

        <button class="btn" @onclick="GoToNextWeek">
            <i class="bi bi-chevron-right"></i>
            <h6>Next</h6>
        </button> 
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Weekly Schedule</h2>
        <AuthorizeView>
            <Authorized>
                @if (context.User.Claims.FirstOrDefault(c => 
                    c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value 
                    is "Admin" or "Instructor")
                {
                    <NavLink class="nav-link" href="create-session">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Add Session
                    </NavLink>
                }
            </Authorized>
        </AuthorizeView>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert @(isSuccess ? "alert-success" : "alert-error")">
            @errorMessage
        </div>
    }

    <div class="scheduler-grid">
        @for (int i = 0; i < 7; i++)
        {
            var targetDate = currentStartDate.AddDays(i);
            var daySessions = sessions
                .Where(s => s.StartTime.Date == targetDate.Date)
                .OrderBy(s => s.StartTime)
                .ToList();

            <div class="day-column">
                <div class="day-header">
                    <span class="day-name">@targetDate.ToString("ddd")</span>
                    <span class="day-date">@targetDate.ToString("MMM d")</span>
                </div>

                <div class="sessions-list">
                    @if (!daySessions.Any())
                    {
                        <div class="no-classes">No Classes</div>
                    }
                    else
                    {
                        @foreach (var session in daySessions)
                        {
                            var (bg, border) = GetSessionColour(session.Name);
                            <div class="session-card ..." 
                                style="background: @bg; border-color: @border;"
                                @onclick="() => HandleSessionClick(session)">
                                <div class="name">@session.Name</div>
                                <div class="time">@session.StartTime.ToString("h:mm tt") @Duration(session) min</div>
                                <div class="instructor">@session.Instructor</div>
                                <div class="meta">
                                    <span>
                                        @if (bookedSessionIds.Contains(session.Id))
                                        { <text>✓ Booked</text> }
                                        else if (session.Capacity <= 0)
                                        { <text>Fully Booked</text> }
                                        else if (session.StartTime <= DateTime.Now)
                                        { <text>Session Passed</text> }
                                        else
                                        { <text>@session.Capacity spots available</text> }
                                    </span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

    <Popup @bind-Visible="showPopup">
        <div class="popup-content" style="text-align: center; padding: 10px;">
            <h3 style="text-transform: uppercase; margin-bottom: 20px;">Confirm Booking</h3>
            
            @if (selectedSession != null)
            {
                <div style="margin-bottom: 20px; line-height: 1.6;">
                    <p style="font-size: 1.2rem; margin-bottom: 5px;">@selectedSession.Name</p>
                    <p>@selectedSession.StartTime.ToString("dddd, MMM d")</p>
                    <p><strong>@selectedSession.StartTime.ToString("h:mm tt")</strong> (@Duration(selectedSession) min)</p>
                    <p>@selectedSession.Description</p>
                    <p class="text-muted">Instructor: @selectedSession.Instructor</p>
                </div>
            }
            <div style="display: flex; gap: 10px; margin-top: 25px;">
                <button class="btn btn-dark w-100" @onclick="HandleBooking">
                    Confirm Booking
                </button>
            </div>
        </div>
    </Popup>

@code 
{
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; } = null!;

    private Booking booking = new();
    private DateTime currentStartDate = DateTime.Today;
    private bool showPopup = false;
    private bool submitted = false;
    private Session? selectedSession;
    private string? errorMessage;
    private List<Session> sessions = new();
    public static UserDTO? CurrentUser;
    private HashSet<long> bookedSessionIds = new();
    private bool isSuccess;

    private bool IsUnavailable(Session s) =>
        s.StartTime <= DateTime.Now || s.Capacity <= 0;

    private ClaimsPrincipal? claimsPrincipal; 

    private (string bg, string border) GetSessionColour(string name)
    {
        var colours = new[]
        {
            ("#E8EEE0", "#C4D0B0"),
            ("#F2E0D0", "#D4B49A"),
            ("#F5ECD9", "#D9C5A0"),
        };
        var index = Math.Abs(name.GetHashCode()) % colours.Length;
        return colours[index];
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }


    private async Task GoToNextWeek()
    {
        currentStartDate = currentStartDate.AddDays(7);
        await LoadSessions();
    }


    private async Task GoToPreviousWeek()
    {
        currentStartDate = currentStartDate.AddDays(-7);
        await LoadSessions();
    }


    private async Task OpenPopup(Session session)
    {
        selectedSession = session;

        var authState = await authenticationStateTask;
        var role = authState.User.Claims
            .FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;

        if (role == "Admin" || role == "Instructor")
            Nav.NavigateTo($"/edit-session/{session.Id}");
        else
            showPopup = true;
    }


    private void ClosePopup() => showPopup = false;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (authenticationStateTask == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var authState = await authenticationStateTask;
        claimsPrincipal = authState.User;

        if (claimsPrincipal.Claims.Count() == 0)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadSessions();
        StateHasChanged();
    }


    private async Task LoadSessions()
    {
        try 
        {
            var url = $"api/Sessions?start={currentStartDate:yyyy-MM-dd}&end={currentStartDate.AddDays(7):yyyy-MM-dd}";

            var result = await Http.GetFromJsonAsync<List<Session>>(url);
            sessions = result ?? new List<Session>();
            
             if (CurrentUser != null)
                {
                    var bookings = await Http.GetFromJsonAsync<List<BookingDTO>>($"api/Bookings/User");
                    bookedSessionIds = bookings?.Select(b => b.SessionId).ToHashSet() ?? new();
                }

            StateHasChanged(); 
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sessions: {ex.Message}");
        }
    }


    private string Duration(Session s) => 
        (s.EndTime - s.StartTime).TotalMinutes.ToString();

    private async Task HandleSessionClick(Session session)
    {
        if (bookedSessionIds.Contains(session.Id))
            Nav.NavigateTo("/bookings");
        else if (!IsUnavailable(session))
            await OpenPopup(session);
    }

    private async Task HandleBooking()
    {
        var authState = await authenticationStateTask;
        if (authState == null) return;

        claimsPrincipal = authState.User;

        if (selectedSession == null) return;

        if (claimsPrincipal == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try 
        {
            if (claimsPrincipal.Claims.Count() == 0)
            {
                Nav.NavigateTo("/login");
                StateHasChanged();
                return;
            }

            var email = claimsPrincipal.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value;

            if (string.IsNullOrEmpty(email))
            {
                Nav.NavigateTo("/login");
                StateHasChanged();
                return;
            }

            var bookingRequest = new 
            { 
                SessionId = selectedSession.Id
            };

            var response = await Http.PostAsJsonAsync("api/Bookings", bookingRequest);
            if (response.IsSuccessStatusCode)
            {
                isSuccess = true;
                errorMessage = "Booking confirmed!";
                showPopup = false;
                await LoadSessions();
                _ = Task.Run(async () =>
                    {
                        await Task.Delay(3000);
                        errorMessage = null;
                        await InvokeAsync(StateHasChanged);
                    });
            }
            else
            {
                isSuccess = false;
                errorMessage = await response.Content.ReadAsStringAsync();
                _ = Task.Run(async () =>
                    {
                        await Task.Delay(3000);
                        errorMessage = null;
                        await InvokeAsync(StateHasChanged);
                    });
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving: {ex.Message}";
        }
        StateHasChanged();
    }
}
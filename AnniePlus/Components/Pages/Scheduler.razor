@page "/scheduler"
@using Annie_API.Models
@inject HttpClient Http

<RadzenSchedulerData="@sessions" TItem="Session" StartProperty="StartTime" EndProperty="EndTime" TextProperty="Name">
    <RadzenMonthView />
    <RadzenWeekView />
</RadzenScheduler>

@code {
    private List<Session> sessions = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await Http.GetFromJsonAsync<List<Session>>("api/Sessions");
        if (result != null)
        {
            sessions = result;
        }
    }
}
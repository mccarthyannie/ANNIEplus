@page "/scheduler"
@using Annie_API.Models
@inject HttpClient Http
@using Syncfusion.Blazor.Schedule
@inject SessionService SessionService

<h3>Schedule</h3>

<SfScheduler TValue="Session" Height="650px" SelectedDate="@DateTime.Today" DataSource="@Sessions">
    <SchedulerViews>
        <SchedulerView Option="View.Week"></SchedulerView>
        <SchedulerView Option="View.Month"></SchedulerView>
    </SchedulerViews>
    <SchedulerEventSettings TEvent="Session" Id="Id" Subject="Name" StartTime="StartTime" EndTime="EndTime" Location="Location"></SchedulerEventSettings>
</SfScheduler>


<RadzenScheduler @ref="scheduler" SlotSelect="OnSlotSelect" AppointmentSelect="OnAppointmentSelect"
                 Data="@appointments" TItem="Appointment" StartProperty="Start" EndProperty="End"
                 TextProperty="Text" Style="height: 600px;">
    <RadzenMonthView />
    <RadzenWeekView />
    <RadzenDayView />
</RadzenScheduler>

@code {
    RadzenScheduler<Appointment> scheduler;
    
    public class Appointment {
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public string Text { get; set; }
    }

    List<Appointment> appointments = new();

    protected override void OnInitialized()
    {
        appointments = Context.Sessions.Select(s => new Appointment {
            Start = s.StartTime,
            End = s.EndTime,
            Text = s.SessionName
        }).ToList();
    }
}
@page "/scheduler"
@using Annie_API.Models
@inject HttpClient Http
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Schedule

<h3>Scheduler Test with Fake Data</h3>

<SfScheduler TValue="Session" Height="650px" SelectedDate="@DateTime.Today" DataSource="@Sessions">
    <SchedulerViews>
        <SchedulerView Option="View.Day"></SchedulerView>
        <SchedulerView Option="View.Week"></SchedulerView>
        <SchedulerView Option="View.Month"></SchedulerView>
    </SchedulerViews>

    <SchedulerEventSettings TEvent="Session"
                            Id="Id"
                            Subject="Name"
                            StartTime="StartTime"
                            EndTime="EndTime"
                            Location="Location">
    </SchedulerEventSettings>

    <!-- Optional: tooltip template to show more info -->
    <SchedulerTooltipTemplate Context="session">
        <div>
            <strong>@session.Name</strong><br />
            @session.Description<br />
            Instructors: @string.Join(", ", session.Instructors)<br />
            Capacity: @session.Capacity<br />
            Location: @session.Location
        </div>
    </SchedulerTooltipTemplate>
</SfScheduler>

@code {
    // Fake data for testing
    private List<Session> Sessions = new()
    {
        new Session
        {
            Id = 1,
            Name = "Yoga Class",
            Description = "Beginner-friendly yoga session",
            StartTime = DateTime.Today.AddHours(9),
            EndTime = DateTime.Today.AddHours(10),
            Capacity = 20,
            Instructors = new List<string>{ "Annie" },
            Location = "Studio A"
        },
        new Session
        {
            Id = 2,
            Name = "Meditation",
            Description = "Mindfulness meditation session",
            StartTime = DateTime.Today.AddHours(11),
            EndTime = DateTime.Today.AddHours(12),
            Capacity = 15,
            Instructors = new List<string>{ "Agustin" },
            Location = "Studio B"
        },
        new Session
        {
            Id = 3,
            Name = "Pilates",
            Description = "Intermediate pilates class",
            StartTime = DateTime.Today.AddDays(1).AddHours(14),
            EndTime = DateTime.Today.AddDays(1).AddHours(15),
            Capacity = 18,
            Instructors = new List<string>{ "Annie", "Agustin" },
            Location = "Studio C"
        }
    };

    // Session model (same as your API model)
    public class Session
    {
        public long Id { get; set; }
        public string? Name { get; set; }
        public string? Description { get; set; }
        public DateTime StartTime { get; set; }
        public DateTime EndTime { get; set; }
        public int Capacity { get; set; }
        public List<string> Instructors { get; set; } = new List<string>();
        public string? Location { get; set; }
    }
}
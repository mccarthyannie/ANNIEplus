@page "/scheduler"
@using Annie_API.Models
@inject HttpClient Http

<h3>Class Schedule</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (sessions == null)
{
    <p><em>Loading schedule...</em></p>
}
else
{
    <RadzenScheduler Data="@sessions" TItem="Session" 
                     StartProperty="StartTime" EndProperty="EndTime" TextProperty="Name">
        <RadzenMonthView />
    </RadzenScheduler>
}

@code {
    private List<Session> sessions = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
{
    try 
    {
        sessions = await Http.GetFromJsonAsync<List<Session>>("api/Sessions");
    }
    catch 
    {
        // If the API fails, fill the calendar with "Mock" data
        sessions = new List<Session>
        {
            new Session { Name = "Yoga Basics", StartTime = DateTime.Today.AddHours(9), EndTime = DateTime.Today.AddHours(10) },
            new Session { Name = "Advanced Flow", StartTime = DateTime.Today.AddDays(1).AddHours(11), EndTime = DateTime.Today.AddDays(1).AddHours(12) }
        };
        errorMessage = "Note: Showing sample data (API disconnected).";
    }
}